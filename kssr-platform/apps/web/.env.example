# Local/offline database (SQLite — a single file, no server needed).
DATABASE_URL="file:./dev.db"

# --- Production examples (switch schema.prisma `provider` to match) ---
# MySQL (Hostinger/Exabytes):
# DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DBNAME"
# PostgreSQL:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"

# Set to true ONLY when serving over HTTPS (e.g. VPS behind Nginx + TLS).
# Leave unset/false for local http:// use.
# COOKIE_SECURE="true"
