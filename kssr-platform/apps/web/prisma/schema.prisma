// Local/offline database for KSSR Adventure Academy.
//
// Uses SQLite (a single file, no server to install) so it runs fully offline.
// For production on a VPS you can keep SQLite for an MVP, or switch `provider`
// to "mysql" (Hostinger/Exabytes) / "postgresql" and re-run migrations.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Real gameplay analytics — written by the client when a game is completed.
// Powers the honest social-proof fallback ("X permainan minggu ini").
model PlayEvent {
  id        String   @id @default(cuid())
  subject   String
  topicId   String
  year      Int
  correct   Int
  total     Int
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Consent-gated social proof. A row is shown ONLY when consentToDisplay = true.
// Names are redacted server-side per displayMode. No row is ever fabricated.
model SocialProofEvent {
  id               String   @id @default(cuid())
  type             String // "purchase" | "registration" | "achievement"
  customerName     String?
  state            String?
  packageName      String?
  detail           String?
  childYear        Int?
  consentToDisplay Boolean  @default(false)
  displayMode      String   @default("firstNameInitial") // firstName|firstNameInitial|stateOnly|hidden
  createdAt        DateTime @default(now())

  @@index([type, consentToDisplay, createdAt])
}

// PDPA-compliant email leads (explicit opt-in, easy unsubscribe).
model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  consent   Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Real customer reviews, managed in the Admin CMS and shown on the landing.
model Review {
  id        String   @id @default(cuid())
  name      String
  place     String?
  text      String
  rating    Int      @default(5)
  photoUrl  String?
  published Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([published, createdAt])
}

// Site-wide settings as simple key/value pairs (managed in the Admin CMS).
// e.g. key="promoEndsAt" value="<epoch-ms>" drives the honest promo countdown.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Uploaded media (pictures) shown on the site — managed in the Media CMS.
model Media {
  id        String   @id @default(cuid())
  filename  String
  url       String
  mimeType  String
  size      Int      @default(0)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Admin-authored questions merged into the games (the content CMS).
model CustomChallenge {
  id        String   @id @default(cuid())
  subject   String
  year      Int
  topicId   String?
  promptEn  String
  promptMs  String
  options   String // JSON: [{ "label": string, "correct": boolean }]
  createdAt DateTime @default(now())

  @@index([subject, year])
}

// ---------------------------------------------------------------------------
// Accounts & profiles. A parent/guardian holds the login; each child is a
// profile under that account (children never log in directly — safer for kids).
// ---------------------------------------------------------------------------
model Account {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String
  passwordHash String
  plan         String         @default("free") // "free" | "bundle"
  role         String         @default("parent") // "parent" | "admin"
  createdAt    DateTime       @default(now())
  children     ChildProfile[]
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([accountId])
}

model ChildProfile {
  id        String   @id @default(cuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name      String
  avatar    String   @default("🦸")
  year      Int      @default(1)
  // Progress snapshot (JSON string): xp, level, coins, stars, streak, mastery…
  progress  String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
}
