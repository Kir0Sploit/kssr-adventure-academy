        { "id": "y1-m2-3", "topicId": "y1-math-addsub-10", "subject": "math", "year": 1, "difficulty": "core", "mechanic": "gate-pass", "prompt": { "en": "7 − 2 = ?", "ms": "7 − 2 = ?" }, "options": [{ "id": "a", "label": "5", "correct": true }, { "id": "b", "label": "4", "correct": false }, { "id": "c", "label": "6", "correct": false }], "hint": { "en": "Count back 2.", "ms": "Kira undur 2." }, "skills": ["subtraction"] },
