        { "id": "y1-m2-6", "topicId": "y1-math-addsub-10", "subject": "math", "year": 1, "difficulty": "stretch", "mechanic": "gate-pass", "prompt": { "en": "5 + 4 = ?", "ms": "5 + 4 = ?" }, "options": [{ "id": "a", "label": "9", "correct": true }, { "id": "b", "label": "8", "correct": false }, { "id": "c", "label": "10", "correct": false }], "hint": { "en": "5 then 4 more.", "ms": "5 kemudian 4 lagi." }, "skills": ["addition"] }
