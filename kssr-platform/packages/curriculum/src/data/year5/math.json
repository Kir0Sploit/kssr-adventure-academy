      "flashcards": [
        { "id": "y5-math-fc-pc", "topicId": "y5-math-decimals-percent", "title": { "en": "Percentage", "ms": "Peratus" }, "definition": { "en": "Percent means 'out of 100'.", "ms": "Peratus bermaksud 'daripada 100'." }, "example": { "en": "50% of 20 = 10", "ms": "50% daripada 20 = 10" }, "illustration": "💯", "hint": { "en": "10% = divide by 10.", "ms": "10% = bahagi dengan 10." }, "funFact": { "en": "0.5 is the same as 50%.", "ms": "0.5 sama dengan 50%." } }
