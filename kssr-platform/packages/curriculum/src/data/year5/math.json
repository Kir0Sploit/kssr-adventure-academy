        { "id": "y5-m1-5", "topicId": "y5-math-decimals-percent", "subject": "math", "year": 5, "difficulty": "stretch", "mechanic": "lane-select", "prompt": { "en": "25% of 80 is?", "ms": "25% daripada 80 ialah?" }, "options": [{ "id": "a", "label": "20", "correct": true }, { "id": "b", "label": "25", "correct": false }, { "id": "c", "label": "40", "correct": false }], "hint": { "en": "A quarter of 80.", "ms": "Satu perempat 80." }, "skills": ["percentage"] },
